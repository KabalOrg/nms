# ==========================================
# ОСНОВНІ НАЛАШТУВАННЯ
# ==========================================
# Префікс твоєї системи (буде в логотипі, табах браузера і привітанні бота)
NMS_PREFIX=Kabal

# Пароль для входу в веб-адмінку
ADMIN_PASSWORD=твій_супер_складний_пароль

# ==========================================
# SNMP НАЛАШТУВАННЯ (Equicom PING3 та інші)
# ==========================================
# Стандартне ком'юніті (якщо у вузла не вказано індивідуальне)
SNMP_COMMUNITY=public

# OID для зчитування напруги (за замовчуванням для Equicom)
VOLTAGE_OID=.1.3.6.1.4.1.35160.1.16.1.13.4

# OID для перевірки наявності мережі 220V (датчик)
POWER_OID=.1.3.6.1.4.1.171.10.113.1.3.2.2.1.1.5.1

# ==========================================
# ТЕЛЕГРАМ БОТ
# ==========================================
# Токен бота, отриманий від @BotFather
BOT_TOKEN=123456789:AAH_твій_довгий_токен_сюди

# ID користувачів, яким дозволено спілкуватися з ботом (через кому)
ALLOWED_USERS=123456789,987654321

# ==========================================
# DEYE CLOUD API (Гібридні інвертори)
# ==========================================
DEYE_APPLD=твій_app_id_від_deye
DEYE_APPSECRET=твій_app_secret
DEYE_LOGIN=твій_email@в_deye_cloud.com
DEYE_PASS=пароль_від_deye_cloud

# ==========================================
# АПАРАТНИЙ ДОЗВІН (PBX)
# ==========================================
# Твій номер телефону, на який буде дзвонити АТС при критичній аварії
ADMIN_PHONE=+380501234567
